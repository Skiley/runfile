{
	"$schema": "./schemas/v0.schema.json",
	"globals": {
		"addToPath": [
			"target/debug"
		],
		"env": {
			"CARGO_TERM_COLOR": "always"
		},
		"forceShell": "sh",
		"logging": true
	},
	"targets": {
		"ci:build": {
			"commands": "cargo build --locked --release {{ ARGS }}",
			"description": "Release build for CI runners (default target dir)"
		},
		"ci:check": {
			"commands": [
				"cargo fmt --all -- --check",
				"cargo clippy --all-targets --all-features --locked -- -D warnings",
				"cargo check --all-targets --all-features --locked"
			],
			"description": "Non-mutating CI gate: format check + Clippy (deny warnings) + type/borrow check"
		},
		"ci:test": {
			"commands": "cargo test --workspace --all-features --locked {{ ARGS }}",
			"description": "Run all workspace tests (default target dir)"
		}
	}
}
