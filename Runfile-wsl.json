{
	"$schema": "./schemas/v0.schema.json",
	"globals": {
		"addToPath": [
			"target/debug"
		],
		"logging": true,
		"workingDirectory": "runfileParent"
	},
	"targets": {
		"build": {
			"description": "Build all crates in debug mode using WSL",
			"commands": "wsl --shell-type login -- cargo build $(ARGS) --target-dir target-linux"
		},
		"build:release": {
			"description": "Build all crates in release mode using WSL",
			"commands": "wsl --shell-type login -- cargo build --release $(ARGS) --target-dir target-linux"
		},
		"lint": {
			"description": "Completely lints (type-checks, formats, runs Clippy) the project using WSL",
			"commands": [
				"wsl --shell-type login -- cargo check",
				"wsl --shell-type login -- cargo fmt --all",
				"wsl --shell-type login -- cargo clippy --all-targets --all-features -- -D warnings"
			]
		},
		"test": {
			"description": "Run all workspace tests using WSL",
			"commands": "wsl --shell-type login -- cargo test $(ARGS) --target-dir target-linux"
		}
	}
}
