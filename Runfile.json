{
	"$schema": "./schemas/v0.schema.json",
	"globals": {
		"env": {
			"CARGO_TARGET_DIR": "target-{{ RUN.os }}"
		},
		"logging": true
	},
	"includes": [
		{
			"namespace": "wsl",
			"path": "Runfile-wsl.json"
		}
	],
	"targets": {
		"build": {
			"description": "Build all crates in debug mode",
			"commands": [
				"cargo build {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build"
				},
				"@install"
			]
		},
		"build:release": {
			"description": "Build all crates in release mode",
			"commands": [
				"cargo build --release {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build:release"
				}
			]
		},
		"bump": {
			"description": "Bumps the workspace version (major/minor/patch) in Cargo.toml, refreshes Cargo.lock, then commits",
			"commands": [
				"{{ define(part, one_of(ARGS, 'major', 'minor', 'patch')) }}",
				"{{ define(cargo, read_file('Cargo.toml')) }}",
				"{{ define(cur, regex_capture(VARS.cargo, 'version = \"([^\"]+)\"', '1')) }}",
				{
					"match": "{{ VARS.part }}",
					"cases": {
						"major": "{{ define(new, concat(add(nth(VARS.cur, '.', '0'), '1'), '.0.0')) }}",
						"minor": "{{ define(new, concat(nth(VARS.cur, '.', '0'), '.', add(nth(VARS.cur, '.', '1'), '1'), '.0')) }}",
						"patch": "{{ define(new, concat(nth(VARS.cur, '.', '0'), '.', nth(VARS.cur, '.', '1'), '.', add(nth(VARS.cur, '.', '2'), '1'))) }}"
					}
				},
				"{{ define(updated, replace_all(VARS.cargo, concat('version = \"', VARS.cur, '\"'), concat('version = \"', VARS.new, '\"'))) }}",
				"{{ write_file('Cargo.toml', VARS.updated) }}",
				"cargo update --workspace",
				"echo 'Bumped: version {{ VARS.cur }} -> {{ VARS.new }}'",
				"git commit Cargo.toml Cargo.lock -m {{ shell_quote(concat('bump to ', VARS.new)) }}"
			],
			"forceShell": "sh"
		},
		"clean": {
			"description": "Remove build artifacts",
			"commands": [
				{
					"for": "dir",
					"in": [
						"",
						"-linux",
						"-mac",
						"-windows"
					],
					"do": "cargo clean --target-dir target{{ VARS.dir }}"
				}
			]
		},
		"install": {
			"description": "Copies the built binary to .local/bin",
			"commands": [
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "{{ define(executable, 'run.exe') }}",
					"else": "{{ define(executable, 'run') }}"
				},
				"cp {{ ENV.CARGO_TARGET_DIR }}/debug/{{ VARS.executable }} ~/.local/bin/{{ VARS.executable }}"
			],
			"detach": true,
			"forceShell": "sh",
			"parallel": true
		},
		"lint": {
			"description": "Completely lints (type-checks, formats, runs Clippy) the project",
			"commands": [
				"cargo check",
				"cargo fmt --all",
				"cargo clippy --all-targets --all-features -- -D warnings",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:lint"
				}
			]
		},
		"miri": {
			"description": "Run Miri (UB checker) on the pure-logic crates (no FFI / no process spawning)",
			"commands": [
				"cargo +nightly miri test -p runfile-crypto",
				"cargo +nightly miri test -p runfile-parser",
				"cargo +nightly miri test -p runfile-env",
				"cargo +nightly miri test -p runfile-shell"
			]
		},
		"miri:setup": {
			"description": "One-time: install the nightly Miri component and build its sysroot",
			"commands": [
				"rustup toolchain install nightly --component miri",
				"cargo +nightly miri setup"
			]
		},
		"release": {
			"description": "Bumps the version, tags the commit, then pushes everything so CI runs the release",
			"commands": [
				"@bump {{ ARGS }}",
				"{{ define(tag, concat('v', VARS.new)) }}",
				"echo Tagging {{ VARS.tag }}",
				"git tag {{ shell_quote(VARS.tag) }}",
				"git push",
				"git push --tags"
			],
			"forceShell": "sh"
		},
		"test": {
			"description": "Run all workspace tests",
			"commands": [
				"cargo test {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:test"
				}
			]
		}
	}
}
